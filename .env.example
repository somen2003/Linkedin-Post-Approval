# ============================================================
# SMTP Configuration (works with Gmail / SendGrid / SES / any SMTP)
# ============================================================
# Examples:
#   Gmail:    smtp.gmail.com:587   (use app password)
#   SendGrid: smtp.sendgrid.net:587
#   AWS SES:  email-smtp.us-east-1.amazonaws.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=your_gmail@gmail.com
SMTP_FROM_NAME=Cipher Marketing Approvals

# ============================================================
# Application
# ============================================================
# IMPORTANT: BASE_URL must be the publicly reachable URL of this app.
# Local dev: http://localhost:8000
# Production: https://your-app.onrender.com  (or your custom domain)
# Approval email buttons are built from this URL — if it's wrong, links break.
BASE_URL=http://localhost:8000

DATABASE_URL=sqlite:///./data.db
ACTION_TOKEN_EXPIRY_DAYS=7

# ============================================================
# Admin Dashboard (HTTP Basic Auth)
# ============================================================
# These credentials protect /dashboard. Share with no one.

